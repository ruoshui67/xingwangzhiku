[node name="卡尔" type="StaticBody3D" parent="." unique_id=518742905]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 1.3128848, 1.05, 7.815694)
script = ExtResource("2")
dialogue_box_path = NodePath("../UI/DialogueBox")
dialogue_label_path = NodePath("../UI/DialogueBox/DialogueScroll/DialogueText")
dialogue_text = "卡尔·贝克尔坐在对面，双手放在膝盖上。"
dialogue_lines = Array[String](["墙上军官的相框被摘走了，留下一块深色的长方形痕迹，像墙上的伤疤。穿绿灰色大衣的男人坐在你对面，双手放在膝盖上，指关节发白。他是卡尔·贝克尔，鞋匠，四十二岁，住在伊岑巷。第七个失踪的法国兵——列兵让·杜邦——最后一次被看见的地方，距他的店铺不到三百英尺。", "卡尔：（清了清嗓子，但没有看你的眼睛）
「所以……您是柏林来的探员。他们说您是来——帮忙的。」", "他的重音落在\"帮忙\"两个字上，像在品一颗变质的橄榄。", "【帝国幽灵】 他说的不是\"帮忙\"。是\"帮——忙\"。一个缓刑囚犯看着另一个缓刑囚犯被请进法官的休息室。他知道你是什么人。一个战败国的警察，在占领者的地盘上。你和他一样，都是戴着手铐在走路的人。", "【普鲁士纪律】 程序：确认受询问者身份。你应当先让他说清楚他的名字、年龄、职业。这是警察手册第一条。不管你是在柏林还是在科隆，流程就是流程。保持流程，你就不会迷失。", "【莱茵河畔】 他的手上有茧，拇指根部有被锥子刺穿后留下的旧疤。那不是握枪的手。那是做靴子的手，修鞋的手，供养家庭的手。他大概有一把年纪足够大的儿子——也许死在了某个战壕里。他看着你，就像看着另一个被生活骗了的人。"])
speaker_sequence = Array[String](["npc", "npc", "npc", "npc", "npc", "npc"])
player_portrait_path = NodePath("../UI/PortraitPlayer")
npc_portrait_path = NodePath("../UI/PortraitNpc")
npc_portrait_texture = ExtResource("63")
choice_panel_path = NodePath("../UI/ChoicePanel")
dice_panel_path = NodePath("../UI/DicePanel")
npc_name = "卡尔"
ground_offset = 0.9
choice_lines = Array[String](["【普鲁士纪律】确认身份", "【莱茵河畔】安抚", "【灰烬喉】沉默凝视", "【红衣逻辑】推理质问", "【对话】直接问"])
choice_responses = Array[String](["卡尔放松了一点——程序让他觉得这是个\"正经警察\"。", "卡尔眼神闪了一下——你说了\"德语\"。", "卡尔紧张，坐得更直了，指关节更白了。", "卡尔眼神微妙变化——他有话没说。", ""])
choice_dice_idx = 3
choice_response_fail = "卡尔困惑地皱眉：「对不起，我不太明白您的意思……士兵难道不都应该是模范的吗？」"
follow_up_lines = Array[String](["卡尔慢慢深吸一口气，目光落在窗框上剥落的漆皮上。", "卡尔：
「那个晚上……上周四。我做活到很晚，过了十一点。那天有个单子急，一个军官要一双新靴子——宪兵的翻毛靴。我在赶工。」", "【普鲁士纪律】 他说\"一个军官\"。没有说法国军官。他在小心翼翼地避开那个词，好像说出来会弄脏自己的舌头。", "【莱茵河畔】 周四晚上十一点做靴子。为一个占领军的军官。他痛恨死了这份活，但他得吃饭。", "【帝国幽灵】 翻毛宪兵靴——那是杜瓦尔身上穿的那种。他给杜瓦尔的手下做靴子。"])
follow_up_speakers = Array[String](["npc", "npc", "npc", "npc", "npc"])
follow_up_choice_lines = Array[String](["【铁十字】占领军在你店里订靴子", "【对话】你听到了什么？", "【灰烬喉】上周四晚，具体几点？", "【普鲁士纪律】有没有留下线索？", "【莱茵河畔】要喝口水再讲吗？"])
follow_up_choice_responses = Array[String](["卡尔沉默片刻，低声说：\"日子总得过。\"", "", "卡尔回答得更快了，语气简短。", "卡尔皱眉回忆：\"声音……先是很闷的一声，然后是拖拽声……\"", "卡尔放松了些，用更口语化的方式开始讲述。"])
follow_up_choice_journal_clues = Array[String](["", "", "", "□ 声音线索 —— 拖拽声 + 低声骂人（德语）", ""])
follow_up_choice_dice_idxs = Array[int]([0, 3, 4])
follow_up_choice_response_fail = "卡尔摇头：\"天太黑，我什么也没看见。\""
follow_up2_lines = Array[String](["卡尔：
「我听到……外面有声音。运河水闸那边，大概离我铺子——唔——一百来尺。起初以为又是野猫在打架。运河边常有人见到野猫……后来声音不对了。」", "他停了下来，指尖摩擦着大拇指的老茧。", "【枯玫瑰】 停顿。一个说故事的人在犹豫是否要讲下去。他在衡量——衡量说出来之后的代价。一个德国人说出了对法国士兵之死有用的信息。沉默是黄金，黄金在这里比马克值钱。", "【红色脉搏】 \"运河边常有人见到野猫\"。不——人。运河边常有人见到的是人。抵抗组织的人。他们是\"野猫\"。他差点说出点什么。"])
follow_up2_speakers = Array[String](["npc", "npc", "npc", "npc"])
follow_up2_choice_lines = Array[String](["【红色脉搏】铁之心碰头的地方？", "【莱茵河畔】声音怎么不对劲？", "【帝国幽灵】和围城战有关吗？", "【对话】声音怎么不对了？", "【灰烬喉】说下去。"])
follow_up2_choice_responses = Array[String](["卡尔脸色发白：\"我不知道您在说什么。\"", "卡尔低声说：\"有人……在说话。用德语。但压得很低，像是在骂人。\"", "卡尔眼神恍惚了一瞬：\"不像战争。比战争——安静。像有人故意不出声的那种安静。\"", "卡尔说：\"好像……有人在拖什么东西。\"", "卡尔吞咽了一下，声音变得更小。"])
follow_up2_choice_journal_clues = Array[String](["", "□ 声音线索 —— 拖拽声 + 低声骂人（德语）", "", "", ""])
follow_up2_choice_dice_idxs = Array[int]([0, 1, 2])
follow_up3_lines = Array[String](["卡尔：
「我没……我没敢开窗。就从铺子后门的门缝往外看了一眼。月亮被云遮了大半，运河边——黑压压的。但我看到——有两个影子。」", "他伸出手，做了个动作——手掌竖着比了比高度。", "【红衣逻辑】 两个影子。一个高，一个矮一些。或者——一个站着的人，和一个被拖行的人。如果杜邦是那个被拖行的，那么那个站着的人至少比杜邦高出半个头……", "【普鲁士纪律】 等一下。两个影子——这不一定是犯罪者和受害者。这还可能是两个犯罪者。或者一个犯罪者和一个——帮凶。你要问清楚他到底看到了什么。"])
follow_up3_speakers = Array[String](["npc", "npc", "npc", "npc"])
follow_up3_choice_lines = Array[String](["【红衣逻辑】影子的位置关系？", "【普鲁士纪律】描述体态", "【铁十字】闻到什么？", "【枯玫瑰】为什么必须看一眼？", "【对话】能认出是谁吗？"])
follow_up3_choice_responses = Array[String](["卡尔想了想：「一前一后。前面那个人……好像低了一下头，就像看地上的东西。」", "卡尔：「一个高一些，一个矮一些。高的那个走路的脚步——很稳。像——军人。」", "卡尔忽然皱眉：「你这么说……好像有股怪味。一种……油的味道。」", "卡尔沉默了很久：「因为我知道那天晚上会发生点什么。那条街上的人都知道。」", "卡尔摇头：「没能。」"])
follow_up3_choice_journal_clues = Array[String](["", "□ 体态线索 —— 两个影子，一个步伐稳健似军人", "□ 气味线索 —— 可疑的油味", "", ""])
follow_up3_choice_dice_idxs = Array[int]([0, 2, 3])
follow_up4_lines = Array[String](["卡尔：
「我知道的就这些了。我后来关好门，上楼去睡觉了。第二天早上宪兵就来了。」", "他终于抬头看了你一眼。那眼神里有一种复杂的、像锁扣一样的东西。", "【莱茵河畔】 他害怕他说的太多了。一个德国人给法国占领军的案件提供线索——这是背叛。你会拿到这些信息，做成一份报告，交给走廊里那个法国女人。她说一声\"谢谢合作\"，然后什么也不会改变。", "【铁十字】 但他还是说了。他知道租界的规矩——法国人是房东，他是租客，你也是。你们都是在这座城市里寄人篱下的人。区别在于——你知道自己是个过客，他知道自己无处可去。", "【普鲁士纪律】 询问结束。你该决定下一步了。要么让他走，要么——再深挖一下。"])
follow_up4_speakers = Array[String](["npc", "npc", "npc", "npc", "npc"])
follow_up4_choice_lines = Array[String](["【莱茵河畔】谢谢，没有下一次", "【铁十字】你认识杜邦吗？", "【普鲁士纪律】不要离开科隆", "【红色脉搏】野猫怎么找？", "【对话】你觉得他死了吗？"])
follow_up4_choice_responses = Array[String](["卡尔的手微微松开了一点。", "卡尔犹豫：「有……有一次他来取隔壁裁缝做的衣服，从我门口经过。蓝眼睛。很年轻。」", "卡尔面无表情：「是，探员先生。」", "卡尔压低声音：「运河第三座桥，桥底下有块松动的石头。」", "卡尔用很久才回答：「我希望他死了。死了的兵不会让人再想起战争。」"])
follow_up4_choice_journal_clues = Array[String](["", "□ 杜邦人物细节 —— 蓝眼睛，年轻，不像兵", "", "□ 抵抗组织联系 —— 运河第三座桥的暗号", ""])
follow_up4_choice_dice_idxs = Array[int]([1, 3])
scene_end_text = "卡尔·贝克尔站起来，驼着背走向门口。经过走廊时，杜瓦尔中尉侧身让开了一条缝。他们的目光没有相遇。
门关上了。房间里只剩下漂白的方形墙痕，和从运河方向飘进来的——某种若有若无的气味。"
