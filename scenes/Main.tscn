dice_panel_path = NodePath("../UI/DicePanel")
npc_name = "汉斯"
ground_offset = 0.9
choice_lines = Array[String](["【普鲁士纪律】公事公办", "【莱茵河畔】展示打火机", "【红衣逻辑】别绕弯子", "【帝国幽灵】亲法标签", "【对话】那天什么情况？"])
choice_responses = Array[String](["汉斯点点头：「好，公事公办。」他从兜里摸出烟斗，在椅腿上磕了磕，没有点。", "汉斯拿起打火机翻了个面，摸到自己修过的打火轮，低声说：「是我修的。」他抬头看你一眼——那一眼多了一点点东西。", "汉斯微微一愣，然后笑了一声——不是嘲笑，是\"碰上一个能听懂话的人\"的那种笑。「不正常。他不正常。」", "汉斯沉默了一会儿。然后用一种很轻的声音说：「我没有亲法。我只是不恨——不恨某一个具体的人。恨一个抽象的东西太累了，探员先生。我修过太多坏掉的机器——比你想象的要多。坏掉的机器都是一样的……不管它上面写着德语还是法语。」", ""])
choice_dice_idxs = Array[int]([2, 3])
follow_up_lines = Array[String](["汉斯：（他拿回打火机，用拇指磨了磨打火轮）
「这东西——杜邦拿给我的时候，打火轮卡死了。不是磨损——是撞的。有人把它往硬东西上拍过。墙上。石头上。反正是平的、硬的东西。」", "他把打火机举到灯光下。
「这儿——看到没？边缘有块凹痕。不是摔的。摔的痕迹更散。这种——集中在一点上的撞击——」
他顿了一下。
「——像是有人把他按在墙上，口袋里的打火机被撞碎了。」", "【红衣逻辑】 打火机被撞碎——不是打斗，是被控制。杜邦在某个时间点上被人按在了墙上。汉斯看到的是物理痕迹，但物理痕迹的背后是一个姿势。——一个警告。把它放下，别再查了。", "【普鲁士纪律】 把这一条记下来。杜邦在失踪前收到过暴力警告。汉斯·福克斯是唯一一个能在法庭上对这件物证做技术鉴定的人。他不是目击者——他是你的专家证人。", "【枯玫瑰】 汉斯说\"像是有人把他按在墙上\"的时候声音没有变。他在描述一件发生在他的手艺人同行身上的暴力——不是没有感情，是感情都收到了技术术语后面。"])
follow_up_speakers = Array[String](["npc", "npc", "npc", "npc", "npc"])
follow_up_choice_lines = Array[String](["【红衣逻辑】这说明什么？", "【普鲁士纪律】法庭鉴定", "【枯玫瑰】你想过那个人吗？", "【帝国幽灵】他怎么解释的？", "【对话】杜邦怎么说的？"])
follow_up_choice_responses = Array[String](["汉斯把烟斗从嘴里拔出来：「说明那个人不想杀他。至少当时不想。是想让他——闭嘴。闭嘴和让他永远闭嘴是两件事。那天他离开我店的时候，他是\"闭嘴\"了。但不是永远。」", "汉斯认真起来：「可以。撞击面大约两点五厘米乘一点二厘米的矩形凹陷区——看起来像是砖墙的棱角，不是石头的光面。角度——从口袋向外，推测他在被撞的时候口袋面朝外贴着墙。」", "汉斯沉默了很久。绿罩灯的影子在他脸上晃了一下。「……会的。」他把打火机放在桌上，第一次不看着它。「他走的时候我说\"下周来拿\"。他说好。我没等到下个星期。」", "汉斯吸了一口烟斗，慢慢吐出来。「他说——'有人误会了。我已经跟他说清楚了。'我说——你的打火机不像是误会。他说——是，但它会再亮起来的。跟他修好的打火机一样。然后他笑了。」汉斯盯着烟斗的火星。「他笑起来——不像个兵。比兵干净。」", "汉斯：「说是撞到了墙。但我觉得不是他自己撞的。」"])
follow_up_choice_journal_clues = Array[String](["□ 杜邦被多次警告而非一次性清除", "□ 打火机鉴定 —— 故意撞击，非意外摔落", "□ 杜邦性格变化 —— 受过警告但相信自己能摆平", "", ""])
follow_up_choice_dice_idxs = Array[int]([0, 2, 3])
follow_up2_lines = Array[String](["汉斯：（他的烟斗已经灭了。他把烟斗搁在桌沿上）
「那个晚上——杜邦失踪的那天晚上。我在工坊里改一张图纸。倒不是特意熬夜——一画就忘了时间。」", "他揉了揉眼睛。
「大概——一点左右。准确地说，过了十二点。我听到了几声响。从运河那边传来的。铁器撞击的声音。」
他伸出三根手指。
「三下。很规律。第一下——停了个呼吸。第二下——停了个呼吸。第三下。然后没了。」", "【红衣逻辑】 三下。规律。有间隔。这不是意外碰撞——这是信号。有人在运河边用铁器发出暗号。", "【红色脉搏】 \"铁器\"。运河。船。系船柱是铁的。第三座桥——卡尔说的暗号石就在第三座桥下面。", "【帝国幽灵】 科隆围城战的时候，信号不只是军号。石匠敲石头、铁匠敲铁轨、牧师敲钟——一个被围困的城市会把任何能发出声音的东西变成暗语。那些节奏活过了围城、活过了投降、活过了占领。现在有人在运河边敲给另一个人听。"])
follow_up2_speakers = Array[String](["npc", "npc", "npc", "npc", "npc"])
follow_up2_choice_lines = Array[String](["【红色脉搏】重现节奏", "【红衣逻辑】敲什么？", "【帝国幽灵】什么意思？", "【普鲁士纪律】方位？", "【对话】没出去看看？"])
follow_up2_choice_responses = Array[String](["汉斯拿起烟斗在桌上敲了三下——梆。梆。梆。节奏像心跳，间隔一致。「就是这样。」你知道这不是求救信号。这是\"已到达\"。或者\"已处理\"。", "汉斯马上回答：「系船柱。运河边的系船柱是铸铁的，空心的——敲起来声音传得很远。还有沿河的消防栓盖子，也是铁铸的。不过系船柱更高，敲的人不用弯腰。」", "汉斯把烟斗放回嘴里，吸了一口已经灭了的烟，慢慢地说了出来：「'完了'。我觉得是。三下——不是钟声的'三、三、九'那种——是结束的那种。像木匠钉好一个箱子，最后敲三锤一样。」他顿了顿：「我们都是从那年活下来的人。有些声音的意思我们不用学。」", "汉斯闭眼回忆：「偏下——不是上游。应该是第三座桥再往下一点的位置。可能是沿着仓库那边。」", "汉斯：「我没出去。外面太黑了。而且——」他没说完。卡尔没说完。汉斯也没说完。科隆人在晚上不出门的理由不用解释。"])
follow_up2_choice_journal_clues = Array[String](["□ 金属撞击三下 —— 系船柱信号，\"已完成\"", "", "", "", ""])
follow_up2_choice_dice_idxs = Array[int]([0, 1, 2])
follow_up3_lines = Array[String](["汉斯：（他犹豫了一下）
「杜邦先生来找我不只是修打火机。」
他把烟斗放在桌上。「他看到了我的图纸——一个有问题的火花塞，我管它叫FZ-7。绝缘材料一直找不好。他没说多的话，拿起来在灯下看了两秒——然后直接问我：'这里面有油吗。'」", "汉斯看着你。那种眼神是——同行在看同行，看你能不能听懂下一句。
「一个普通的步兵不会知道火花塞里面有没有油。更不会只看了两眼就问到那个零件的位置。杜邦入伍前就是搞机械的——他不是随便问问。他是想知道——我在使用的燃料，是不是同一种。他在查东西。他知道自己在查什么。他不是在瞎转。」", "【红衣逻辑】 杜邦在你铺子里说了\"里面有没有油\"。他是想知道火花塞用的是什么燃料。为什么？因为他见过那种燃料。他在某个地方认出了一种特殊的油——军用燃料。他找到了你，不是修打火机——是求证。", "【普鲁士纪律】 你注意到：汉斯在转述\"里面有没有油\"的时候——他把杜邦的话放在了自己的描述前面。这个人的记忆以准度为单位。", "【铁十字】 你在科隆围城战中被围了两个月。你记得燃料的味道。你知道汉斯给了杜邦那个答案——因为汉斯修东西，不修政治。但给完之后呢？他把杜邦打发出门，看着这个年轻人走进十月的夜里——去追那些\"里面有油\"的东西。然后杜邦再也没有回来过。"])
follow_up3_speakers = Array[String](["npc", "npc", "npc", "npc", "npc"])
follow_up3_choice_lines = Array[String](["【红衣逻辑】你用的什么燃料？", "【铁十字】油从哪来的？", "【普鲁士纪律】详细描述燃料", "【帝国幽灵】你没说别查了？", "【对话】军用燃料？"])
follow_up3_choice_responses = Array[String](["汉斯：「我告诉了他。我用的是一种混合油——从裁缝布店买来的，说是什么'灯油'。但我在试的时候知道那不是灯油。灯油烟大，发黑。这个油——火焰蓝到发白，温度比我任何燃料都高。」他停了。「他听完就说'我知道这东西来自哪里'。然后他就走了。」", "汉斯沉默。然后慢慢说：「这种事——我不问。但如果你非要问的话——那东西不是市场上随便买到的。纯度太高。能稳定供应的只有军用仓库。」他把你没说的那半句说了出来：「有人在军方里面往外搬燃料。」", "汉斯正色：「浅琥珀色，比煤油透亮。摇晃起来黏度略高——在瓶壁上有缓慢的挂珠。气味——不是煤油的刺鼻味儿，更甜一点，有点像……变质的松节油混着医院的消毒水。燃烧温度比民用煤油高至少一百度——这绝对不是民用燃料。工业级，军事级的。」", "汉斯看着你，好像你说了什么他没预料到的话。他慢慢地拿起灭了的烟斗在手指间转了转。「……没有。」他的声音很轻。「我应该说。我看着他走出去的。二十二岁。我当时想——这个年轻人比我知道的多。也许他能查到点什么。」他吞了一下。「我应该告诉他'别查了'。」", "汉斯：「我觉得是吧。他认出那种油的时候眼睛亮了——不像是发现有价值的东西，像是——证实了。」"])
follow_up3_choice_journal_clues = Array[String](["□ 杜邦查到了燃料来源并确认", "□ 燃料鉴定 —— 军用混合油，指向军方内部盗窃", "□ 燃料鉴定 —— 军用混合油，工业级军事级", "", ""])
follow_up3_choice_dice_idxs = Array[int]([0, 1, 2, 3])
follow_up4_lines = Array[String](["汉斯：（他站起来把打火机放在桌子正中间。自己的烟斗收进了口袋。收拾完了——收工）
「还有什么需要我帮忙的——」
他顿了一下。没说\"随时来找我\"。他说的是：
「——如果你是来查东西的。如果你是来查人的——」他轻轻摇头。「我不是那种能帮你查人的人。」", "【莱茵河畔】 他愿意帮你查东西。他不愿意帮你查人。这里面的差别不是怕不怕——是\"东西\"不对任何人开枪，而\"人\"会。", "【铁十字】 他和你差不多大。他失去的人和你在柏林失去的人可能不一样——但失去的结果是一样的。一个人在空房间里做火花塞做到凌晨，因为他不想睡觉。你也一样。", "【普鲁士纪律】 笔录做完了。你有一份技术鉴定意见——足够让杜瓦尔拿着去打报告。你有没有别的想问他的？——关于他自己。不是证人。是个人。"])
follow_up4_speakers = Array[String](["npc", "npc", "npc", "npc"])
follow_up4_choice_lines = Array[String](["【莱茵河畔】谢谢", "【帝国幽灵】为什么还在做FZ-7？", "【铁十字】改变主意就找我", "【普鲁士纪律】会通知你出庭", "【对话】今天就到这里"])
follow_up4_choice_responses = Array[String](["汉斯在门口停了一下。他回头看了一眼桌上的打火机。「如果你们抓到了人——那东西不用还了。杜邦不会来取了。」他背对着你说。然后走了。", "汉斯被这个问题钉在了门口。他的背影停了很久。「因为只要它亮一次——哪怕一次——」他的声音像是从很远的地方送过来的。「就有人看见。有人看见就不是没发生过。哪怕看见它的是个法国人。」他推开门出去。没有回头。", "汉斯在门口回头看了你一眼。那种眼神不是感谢——是一种微妙的、技术性的注视。像在给一个新零件归类。「柏林人——不太一样。」他说完，门关上了。", "汉斯点头：「明白。」没有多一个字。", "汉斯站起来，走向门口，没有回头看那张桌子。"])
follow_up4_choice_journal_clues = Array[String](["", "□ 汉斯的FZ-7火花塞 —— 宁可亮一次也不愿放弃", "", "", ""])
follow_up4_choice_dice_idxs = Array[int]([1])
scene_end_text = "绿罩灯还在烧。汉斯的烟斗印在桌面留下了一个浅灰色的圆——烟斗的印子。你拿起杜邦的打火机举到灯下看那道凹痕。火柴划不动。
窗外，杜瓦尔的影子在走廊里移动。她在等你的笔录。"
