dialogue_box_path = NodePath("../UI/DialogueBox")
dialogue_label_path = NodePath("../UI/DialogueBox/DialogueScroll/DialogueText")
dialogue_text = "汉斯·福克斯坐在对面，穿一件沾着机油痕迹的灰色工装。"
dialogue_lines = Array[String](["汉斯：（抬手指了指天花板角落的煤气灯，嘴角有一点弧度）
「那盏灯有个问题——灯芯偏了，左边的火比右边低。你们要是再不管，再过两周它会闪得跟打嗝似的。」", "他放下手，看着你。不是打量，是那种工匠看工具的眼神——在判断你是什么零件。", "【帝国幽灵】 汉斯·福克斯。他的工坊在马厩改建的车库里，离工业区不远。一个德国工匠，在法占区开着铺子。有法国通讯兵去他那里修电台。街坊有人说他\"亲法\"——他听到的时候不辩解，也不笑。这种人比卡尔危险。卡尔不说话，是因为害怕；汉斯不说话，是因为他不觉得有必要。", "【普鲁士纪律】 汉斯·福克斯，三十二岁，伊岑巷附近某旧马厩改造的机修工坊。自愿前来协助调查——至少宪兵通知他时他是这么说的。他不是目击者。他是杜邦的最后一个非军事接触人。你要从\"打火机\"开始，还是从\"杜邦\"开始？", "【莱茵河畔】 他的眼睛在灯下有一种奇异的温度——不是冷漠，是那种早上去敲作坊门时、师傅抬头看你一眼说\"进来吧\"的温度。他不是来被审的。他是来——看看。看看这个柏林来的警察值不值得他把知道的东西拿出来。"])
speaker_sequence = Array[String](["npc", "npc", "npc", "npc", "npc"])
