dialogue_label_path = NodePath("../UI/DialogueBox/DialogueScroll/DialogueText")
dialogue_text = "迪特尔坐在你的对面。他只有二十一二岁，肩膀还没有长开。"
dialogue_lines = Array[String](["迪特尔：（声音压得很低，几乎是自言自语）
「我不认识那个兵。我跟仓库没关系。我每天在仓库里搬东西——就是布。帆布。棉布。粗麻。老板姓沃格桑——奥托·沃格桑。他是个做布料的。有人订了布，我就搬。不订——我就不搬。我不认识任何一个法国兵。」

他说得太快了。一个做好了所有答案的人被单独关在一个房间里太久——那些答案在他脑子里已经背得比《圣经》还熟。", "【普鲁士纪律】 迪特尔。二十二岁。科隆本地人。父亲在1891年围城战中死于法军炮火。在奥托·沃格桑的仓库打工——沃格桑是谁？做布料生意的。他在运河下游的工业区有一间仓库。不是纺织品仓库。是什么你还不确定——但一定不是布。", "【枯玫瑰】 他的额头上有雨渍。外面下雨了。他走路过来的。也许有人带他过来——也许是他自己走来的。如果是自己来的，那他可以在很多条巷子里拐弯。但他来了。为什么？因为他知道自己跑了会更可疑——还是因为他想对什么人说出点什么？", "【红色脉搏】 他父亲是被法国人炸死的。他这辈子都恨法国人。但现在在运河边失踪的是七个法国兵。他帮了德国抵抗组织还是没帮？他在沃格桑的仓库打工——如果仓库里进出的是燃料而不是布料，他不可能不知道。"])
speaker_sequence = Array[String](["npc", "npc", "npc", "npc"])
