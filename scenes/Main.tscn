npc_name = "迪特尔"
post_complete_text = "迪特尔恶狠狠的盯着你，一言不发。"
ground_offset = 0.9
p2_dialogue_lines = Array[String](["迪特尔：（看到进来的是杜瓦尔。制服不一样。肩章不一样。他是法国军官。）
他整个人硬了。他不再划桌子了。他把手放在膝盖上——像在拘留所等判决。", "【共和国准则】 迪特尔。二十二岁。科隆本地人。父亲死于1891年法军炮火。他在沃格桑的仓库工作——奥托·沃格桑。你听说过这个名字。上周莫罗上尉的军需报告里，有一张供货合同上过了他的名。纺织品供应。不大不小的单子。但那个人从没有在仓库门口接过货。他的仓库在工业区边缘。运河边。一个你看不见但知道那里有东西的位置。", "【三段论】 沃格桑在供应纺织品。
但沃格桑的仓库比他的纺织品供应量大一倍。
多出来的空间——要么空了。要么放了别的。
如果放了别的——那个别的进出仓库的时候，一定有这个常年在仓库里做苦力的德国小子看到。"])
p2_speaker_sequence = Array[String](["npc", "npc", "npc"])
p2_choice_lines = Array[String](["【共和国准则 - 简易】
「除了布——还有什么？」", "【三段论 - 挑战（普通）】
「你今晚为什么来了？」", "【三色旗 - 挑战（困难）】
「我可以保证沃格桑不会进来。」"])
p2_choice_responses = Array[String](["迪特尔抬起头。换了人——但问题还是那种问题。他一时不知道该怎么应付一个直接问\"还有什么\"的法国军官。", "迪特尔被\"七次了\"三个字击中。他的手在膝盖上握成了拳。不是气——是道德压力压到了临界点。他小声说了一句：「不止七次。」——第一道裂缝。迪特尔承认他知道的比失踪案本身更多。", "迪特尔看着你，好像在确认你是不是说了真话。然后他慢慢地、像一个憋了很久的人，说：「……铁桶。」他的声音几乎碎了。「铁皮的桶。堆在仓库最里面的暗间后面。盖子上写了法语。油。」——重大突破：迪特尔承认仓库里有法国军用的燃料桶。"])
p2_choice_dice_idxs = Array[int]([1, 2])
p2_choice_response_fail = "迪特尔低下头。「我不是为了法国人来的。」但他没有回到墙里去。他只是不说话——不像之前的那种\"不说\"。"
p2_follow_up_lines = Array[String](["迪特尔：（不再背诵了。声音还是低，但一种泄洪的感觉——说一半，留一半）
「……四年了吧。每个月来几桶——有时候更多。是——是法国人。一个法国军官。个子不高。我不认识名字。他来的时候从来不说话。放下就走。」

他吞了一下。

「老板把桶放在暗间里。有人来取。我不知道是谁。我只负责搬——我告诉你这不关我事——我只是一个干活的——我不是——」

他突然停下来。

「——有一天夜里有人来了。不是来取货的。不是平时的人。他们——」他咬住了嘴唇。", "【共和国准则】 \"他们\"。复数。不是沃格桑。不是取燃料的人。新的一方。抵抗组织。铁之心。弗里德里希。他们在半路上截燃料——从他父亲死了以后他反而被这两种力量夹在中间。法军偷燃料出来，沃格桑转卖，铁之心半路劫走。他是中间的人。", "【三段论】 \"他们\"来的那一天——是不是十月二十一日？杜邦失踪的那一夜。迪特尔看到了什么。他说到\"他们\"的时候就停了——因为接下来他要说的不是别人的事。是他自己的选择。"])
p2_follow_up_speakers = Array[String](["npc", "npc", "npc"])
p2_follow_up_choice_lines = Array[String](["【共和国准则 - 挑战（普通）】
通风报信多久了？", "【三段论 - 挑战（极难）】
十月二十一日桥上发生了什么？"])
p2_follow_up_choice_responses = Array[String](["迪特尔：「……四年。」他回答了。没说细节——但承认了。一个被夹在两个国家中间的人终于松了第一颗扣子。", "迪特尔彻底停止了所有的防御动作。他的手放在膝盖上，不再动。他的眼睛看着杜瓦尔——满是眼泪，但没有流出来。「……他还在动。我看到了。运河边上——他在动。他不是死了——他还在动——他翻了个身——他的手抓着草——」他的声音断了。「……我没有过去。我没有——」他用手掩住嘴。不是悔恨。是恐怖。——终极真相：迪特尔看到杜邦在运河边还活着，但没有施救。弗里德里希按住他不让他动。杜邦可能不是被勒布朗杀死的——而是在河边慢慢失血而死。"])
p2_follow_up_choice_dice_idxs = Array[int]([0, 1])
p2_follow_up_choice_response_fail = "迪特尔摇头：「我不知道您在说什么铁之心。我不知道什么抵抗。」但他的眼睛眨得太快了。
他又低下头：「我不知道那晚发生了什么。我们不在桥上。」但他全身都在说——你们在。"
p2_follow_up2_lines = Array[String](["杜瓦尔：（等待。让沉默做完它的工作。）
「一个叫勒布朗的军士长打完人之后把他丢在了河边。你没有害他——是扔下他的人害的他。你今天来——弗莱探员不明白。但我明白。你不想继续背别人的罪了。」

迪特尔：（把脸从手上拿开）
「那个军官——那个穿法军制服来送货的——上个月说：'如果出事，谁都跑不了。'他说这话的时候看着我。他只看着我。老板当时在单子上签字。老板没听见。我知道他在告诉我——我是最容易杀的那个。一个德国孤儿死在占领区——没有人会查——」

他深吸了一口气。

「我不能死。我——我不能死在监狱里。我父亲死的没有意义。我死的时候——至少——不能也没有意义。」", "【三色旗】 他说\"我父亲死得没有意义\"。在科隆围城战中无名的死者——在法军炮火下化为灰烬的德国平民。你说1891年的战争不是你的。但你身上的制服是1891年活下来的制服。你口袋里那本法兰西共和国的军法手册——是用1891年的尸体堆出来的。", "【共和国准则】 够了。你现在有迪特尔的口供。你有燃料的来源。你知道沃格桑的仓库位置。你知道勒布朗是送货员。你知道迪特尔在桥边听到了杜邦的挣扎。你还缺最后一环——莫罗。莫罗的名字没有出现在迪特尔的口供里，但他的影子已经在这个房间里笼罩了三十八分钟。穿法军制服的军官，个子不高，不说话。你自己认识这个人。"])
p2_follow_up2_speakers = Array[String](["npc", "npc", "npc"])
p2_scene_end_text = "迪特尔站起来的时候腿有点软。他走到门口，回头看了一眼杜瓦尔。

迪特尔：「……你说的。他——沃格桑——不会进来？」

杜瓦尔：「不会。」

迪特尔点了两下头。然后跟着走廊里的宪兵走了。

弗莱站在走廊里。他们隔着门框对视了一秒。

杜瓦尔：「下一个。」

但她没有说\"沃格桑\"。她看着弗莱，眼神里有一种新的东西——是从迪特尔嘴里撬出来的那些话在她脑子里还没有消化。她开始整合了。
（莫罗的名字还没有说出口。但已经不在话里了——已经在她脑子里了。）"
p2_post_complete_text = "迪特尔恶狠狠的盯着你，一言不发。"
choice_lines = Array[String](["【普鲁士纪律 - 简易】
询问身份信息", "【灰烬喉 - 简易】
